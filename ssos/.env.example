# SSOS Environment Configuration
# Copy this file to .env and adjust values as needed

# ── Infrastructure ──────────────────────────────────────────
REDIS_HOST=redis
KAFKA_BROKERS=kafka:29092
POSTGRES_HOST=postgres
POSTGRES_USER=ssos
POSTGRES_PASSWORD=ssos_password
POSTGRES_DB=ssos_db
DATABASE_URL=postgres://ssos:ssos_password@postgres:5432/ssos_db

# ── Service ports ───────────────────────────────────────────
API_GATEWAY_PORT=8000
CROWD_PREDICTION_PORT=8001
ROUTING_ENGINE_PORT=8002
DECISION_ENGINE_PORT=8003
DATA_PIPELINE_PORT=8004
DIGITAL_TWIN_PORT=8005

# ── ML model ────────────────────────────────────────────────
MODEL_PATH=crowd_lstm.pt

# ── Demo mode (set to "true" to skip Kafka, use synthetic data) ─
DEMO_MODE=false
